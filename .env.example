# === Nova VPN Bot — Environment Variables ===

# Telegram Bot (обязательно)
BOT_TOKEN=               # Токен от @BotFather
ADMIN_IDS=               # Telegram ID админов через запятую (например: 123456,789012)

# Hiddify API (обязательно)
HIDDIFY_API_URL=         # URL API Hiddify Panel (например: http://127.0.0.1:9000/YOUR_ADMIN_PATH/api/v2/admin/)
HIDDIFY_API_KEY=         # API ключ из админ-панели Hiddify
HIDDIFY_SUBSCRIPTION_BASE=   # Базовый URL подписок (например: https://your-ip/sub/)
HIDDIFY_CDN_SUBSCRIPTION_BASE=  # CDN URL подписок (если используется Cloudflare)
HIDDIFY_REALITY_DOMAIN=  # Домен для Reality в Hiddify
HIDDIFY_CDN_DOMAIN=      # CDN домен (Cloudflare)

# Standalone Xray Reality (обязательно)
REALITY_HOST=            # IP или домен вашего сервера
REALITY_PORT=8443        # Порт Reality (по умолчанию 8443)
REALITY_PUBLIC_KEY=      # X25519 public key
REALITY_SNI=addons.mozilla.org   # SNI для маскировки
REALITY_FLOW=xtls-rprx-vision
REALITY_FINGERPRINT=chrome

# Google SNI Bypass — TCP через HAProxy (опционально)
BYPASS_HOST=             # IP сервера (обычно тот же, что REALITY_HOST)
BYPASS_PORT=443
BYPASS_DL_PUBLIC_KEY=    # Public key для dl.google.com inbound
BYPASS_DL_SNI=dl.google.com
BYPASS_DL_FINGERPRINT=qq
BYPASS_DL_SID=

# Google SNI Bypass — gRPC (опционально)
BYPASS_GRPC_PORT=2053
BYPASS_GRPC_PUBLIC_KEY=  # Public key для gRPC inbound
BYPASS_GRPC_SNI=www.google.com
BYPASS_GRPC_FINGERPRINT=random
BYPASS_GRPC_SID=

# Пути к Xray конфигам (опционально, дефолты для стандартной установки)
XRAY_CONFIG_PATH=/opt/xray-reality/config.json
XRAY_SERVICE_NAME=xray-reality
HIDDIFY_XRAY_CONFIG_PATH=/opt/hiddify-manager/xray/configs/05_inbounds_02_reality_main.json
HIDDIFY_XRAY_SERVICE_NAME=hiddify-xray

# База данных
DB_PATH=/opt/nova-vpn/data/database.db

# Лимиты
MAX_CONFIGS_PER_USER=3
DEFAULT_USAGE_LIMIT_GB=100
DEFAULT_PACKAGE_DAYS=365

# Логирование
LOG_LEVEL=INFO           # DEBUG, INFO, WARNING, ERROR
